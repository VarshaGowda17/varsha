# Server Configuration
# Set this to your domain name or public IP address for QR codes to work across devices
# Examples:
#   http://yourdomain.com
#   http://192.168.1.100:5000
#   http://10.0.0.5:5000
SERVER_ADDRESS=http://localhost:5000

# Database Configuration (if using MySQL)
# USE_MYSQL=false
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=blockchain_certs

# Session Secret
SESSION_SECRET=your-secret-key-here

# Ganache RPC URL (if using Ethereum)
GANACHE_URL=http://127.0.0.1:8545
